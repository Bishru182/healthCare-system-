# ─────────────────────────────────────────────
# Notification Service – Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# ─────────────────────────────────────────────

# Server
PORT=5005
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27021/notification

# Gmail (Nodemailer) – use a Gmail App Password
EMAIL_USER=
EMAIL_PASS=

# Text.lk SMS (primary SMS provider)
TEXTLK_API_TOKEN=
TEXTLK_SENDER_ID=TextLKDemo

# Optional Text.lk SMS settings
TEXTLK_SMS_API_URL=https://app.text.lk/api/v3/sms/send
TEXTLK_SMS_TYPE=plain

# Twilio (for WhatsApp)
TWILIO_SID=
TWILIO_AUTH=
TWILIO_PHONE=

# Twilio WhatsApp (optional)
# Example sandbox sender: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
