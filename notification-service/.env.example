# ─────────────────────────────────────────────
# Notification Service – Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# ─────────────────────────────────────────────

# Server
PORT=5005
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27021/notification

# Gmail (Nodemailer) – use a Gmail App Password
EMAIL_USER=
EMAIL_PASS=

# Twilio SMS
TWILIO_SID=
TWILIO_AUTH=
TWILIO_PHONE=
