# ──────────────────────────────────────────────
#  Payment Service – Environment Variables
#  Copy this file to .env and fill in values
# ──────────────────────────────────────────────

PORT=3003
MONGO_URI=mongodb+srv://<user>:<password>@books-store-mern.kq25k3n.mongodb.net/medico?appName=Books-Store-MERN
JWT_SECRET=your_jwt_secret_here

CLOUD_NAME=your_cloudinary_cloud_name
CLOUD_API_KEY=your_cloudinary_api_key
CLOUD_API_SECRET=your_cloudinary_api_secret

# Payment gateway provider: mock | stripe | payhere
PAYMENT_PROVIDER=mock

# Stripe (only when PAYMENT_PROVIDER=stripe)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
# Optional: force Stripe sandbox simulation (no Stripe account required)
# true = simulate checkout + webhook events locally
# false = use real Stripe API when STRIPE_SECRET_KEY is set
STRIPE_SANDBOX_MODE=true

# Redirect URLs for online gateway checkout
SUCCESS_URL=http://localhost:5173/patient/payments?gateway=success
CANCEL_URL=http://localhost:5173/patient/payments?gateway=cancelled

# Fallback amount when appointment payload does not include a fee
DEFAULT_APPOINTMENT_FEE=100

# Appointment Service URL (uncomment the one matching your environment)
# APPOINTMENT_SERVICE_URL=http://localhost:3002
# APPOINTMENT_SERVICE_URL=http://host.docker.internal:3002
APPOINTMENT_SERVICE_URL=http://appointment-service:3002

# Optional token used by webhook flow to confirm appointment status via
# PUT /api/appointments/:id/status (must carry authorized role in appointment-service)
APPOINTMENT_SERVICE_TOKEN=

# Notification Service URL (uncomment the one matching your environment)
# NOTIFICATION_SERVICE_URL=http://localhost:5005
# NOTIFICATION_SERVICE_URL=http://host.docker.internal:5005
NOTIFICATION_SERVICE_URL=http://notification-service:5005

# Internal API key for cross-service contact lookups
INTER_SERVICE_API_KEY=medico-internal-key-change-me
